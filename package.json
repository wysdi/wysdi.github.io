{
  "name": "hugo-portfolio",
  "version": "1.0.0",
  "description": "Wayan Sudiarta Portfolio - Built with Hugo & Tailwind CSS",
  "author": "Wayan Sudiarta",
  "license": "MIT",
  "scripts": {
    "build:css": "postcss assets/css/main.css -o static/css/style.css --env production",
    "watch:css": "postcss assets/css/main.css -o static/css/style.css --env development --watch",
    "build": "npm run build:css && hugo --minify",
    "server": "hugo server -D"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "postcss-cli": "^9.0.0",
    "tailwindcss": "^3.0.0"
  }
}
