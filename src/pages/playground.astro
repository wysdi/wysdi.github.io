---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Playground">
  <div class="space-y-16 animate-fade-in">
    <section>
      <h2 class="section-headline">Playground</h2>
      <div class="space-y-6">
        {
          (await getCollection('playground')).map((project) => (
            <div class="card group">
              <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-3 gap-2">
                <h3 class="font-bold text-xl text-primary group-hover:text-accent transition-colors">{project.data.title}</h3>
                {project.data.deployedTo && <span class="badge">Live</span>}
              </div>
              <p class="text-sm font-semibold text-accent mb-2">Project</p>
              <p class="text-sm text-muted mb-4">{project.data.description}</p>
              
              <div class="space-y-4">
                {project.data.deployedTo && (
                  <div class="flex items-center group/link">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-accent/10 to-accent/5 flex items-center justify-center mr-4 group-hover:scale-110 transition-transform duration-200">
                       <svg class="w-5 h-5 opacity-70 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                      </svg>
                    </div>
                    <a href={project.data.deployedTo} target="_blank" rel="noopener noreferrer" class="text-secondary font-medium group-hover:text-accent transition-colors">View Live Demo</a>
                  </div>
                )}

                {project.data.codeOn && (
                  <div class="flex items-center group/link">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-accent/10 to-accent/5 flex items-center justify-center mr-4 group-hover:scale-110 transition-transform duration-200">
                       <svg class="w-5 h-5 opacity-70 group-hover:opacity-100 transition-opacity" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                      </svg>
                    </div>
                    <a href={project.data.codeOn} target="_blank" rel="noopener noreferrer" class="text-secondary font-medium group-hover:text-accent transition-colors">View Code</a>
                  </div>
                )}

                {project.data.builtWith && (
                  <div class="flex flex-wrap gap-2 pt-2">
                    {project.data.builtWith.map((tech) => (
                      <span class="badge">{tech}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
