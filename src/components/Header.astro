---
import { siteConfig } from '../config/site';
---
<header class="py-6 border-b border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex justify-between items-center">
      <a href="/" class="text-xl font-bold text-primary hover:text-accent transition-colors">
        {siteConfig.title}
      </a>
      <ul class="flex space-x-6">
        {siteConfig.menu.map((item) => (
          <li>
            <a href={item.url} class="text-secondary hover:text-accent transition-colors font-medium">
              {item.name}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
