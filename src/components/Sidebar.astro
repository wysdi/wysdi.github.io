---
import { siteConfig } from '../config/site';
---
<aside class="w-full lg:w-80 mb-12 lg:mb-0">
  <div class="sticky top-8 space-y-8">
    <!-- Profile -->
    <div class="text-center lg:text-left card-modern relative overflow-hidden group">
      <div class="absolute -top-10 -right-10 w-32 h-32 bg-accent/5 rounded-full blur-3xl group-hover:bg-accent/10 transition-colors duration-500"></div>
      <div class="relative z-10">
        <h1 class="text-2xl md:text-3xl font-extrabold mb-2 bg-gradient-to-r from-primary via-secondary to-primary bg-[length:200%_auto] animate-gradient bg-clip-text text-transparent whitespace-nowrap">{siteConfig.title}</h1>
        <p class="text-accent font-medium text-lg">Software Engineer</p>
      </div>
    </div>
    
    <!-- Social Links -->
    <div class="card-modern">
      <h2 class="section-headline">Connect</h2>
      <ul class="space-y-3">
        <li class="flex items-center group">
          <a href={`https://github.com/${siteConfig.social.github}`} target="_blank" rel="noopener noreferrer" class="flex items-center w-full p-2 rounded-xl hover:bg-accent/5 transition-all duration-200">
            <div class="w-10 h-10 rounded-xl bg-white/50 dark:bg-white/5 flex items-center justify-center mr-4 group-hover:scale-110 group-hover:bg-white dark:group-hover:bg-white/10 transition-all duration-200 shadow-sm">
              <svg class="w-5 h-5 text-secondary group-hover:text-accent transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
              </svg>
            </div>
            <span class="text-secondary font-medium group-hover:text-accent transition-colors">GitHub</span>
          </a>
        </li>
        <li class="flex items-center group">
          <a href={`https://www.linkedin.com/in/${siteConfig.social.linkedin}/`} target="_blank" rel="noopener noreferrer" class="flex items-center w-full p-2 rounded-xl hover:bg-accent/5 transition-all duration-200">
            <div class="w-10 h-10 rounded-xl bg-white/50 dark:bg-white/5 flex items-center justify-center mr-4 group-hover:scale-110 group-hover:bg-white dark:group-hover:bg-white/10 transition-all duration-200 shadow-sm">
              <svg class="w-5 h-5 text-secondary group-hover:text-accent transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.454C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </div>
            <span class="text-secondary font-medium group-hover:text-accent transition-colors">LinkedIn</span>
          </a>
        </li>
        <li class="flex items-center group">
          <a href={`https://twitter.com/${siteConfig.social.twitter}`} target="_blank" rel="noopener noreferrer" class="flex items-center w-full p-2 rounded-xl hover:bg-accent/5 transition-all duration-200">
            <div class="w-10 h-10 rounded-xl bg-white/50 dark:bg-white/5 flex items-center justify-center mr-4 group-hover:scale-110 group-hover:bg-white dark:group-hover:bg-white/10 transition-all duration-200 shadow-sm">
              <svg class="w-5 h-5 text-secondary group-hover:text-accent transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
              </svg>
            </div>
            <span class="text-secondary font-medium group-hover:text-accent transition-colors">Twitter</span>
          </a>
        </li>
        <li class="flex items-center group">
          <a href="/playground" class="flex items-center w-full p-2 rounded-xl hover:bg-accent/5 transition-all duration-200">
            <div class="w-10 h-10 rounded-xl bg-white/50 dark:bg-white/5 flex items-center justify-center mr-4 group-hover:scale-110 group-hover:bg-white dark:group-hover:bg-white/10 transition-all duration-200 shadow-sm">
              <svg class="w-5 h-5 text-secondary group-hover:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
              </svg>
            </div>
            <span class="text-secondary font-medium group-hover:text-accent transition-colors">Playground</span>
          </a>
        </li>
      </ul>
    </div>
    
    <!-- Skills -->
    <div class="card-modern">
      <h2 class="section-headline">Skills</h2>
      <div class="space-y-4">
        <div>
          <div class="flex justify-between text-sm font-medium mb-1">
            <span class="text-secondary">PHP</span>
            <span class="text-accent">90%</span>
          </div>
          <div class="w-full h-1.5 bg-background-secondary rounded-full overflow-hidden">
            <div class="h-full bg-gradient-to-r from-accent to-accent-hover" style="width: 90%"></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-sm font-medium mb-1">
            <span class="text-secondary">JavaScript</span>
            <span class="text-accent">80%</span>
          </div>
          <div class="w-full h-1.5 bg-background-secondary rounded-full overflow-hidden">
            <div class="h-full bg-gradient-to-r from-accent to-accent-hover" style="width: 80%"></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-sm font-medium mb-1">
            <span class="text-secondary">Python</span>
            <span class="text-accent">70%</span>
          </div>
          <div class="w-full h-1.5 bg-background-secondary rounded-full overflow-hidden">
            <div class="h-full bg-gradient-to-r from-accent to-accent-hover" style="width: 70%"></div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Technologies -->
    <div class="card-modern">
      <h2 class="section-headline">Technologies</h2>
      <div class="flex flex-wrap gap-2">
        {["Symfony", "Django", "React", "Vue", "FastAPI"].map((tech) => (
          <span class="px-3 py-1 rounded-full text-xs font-medium bg-accent/10 text-accent border border-accent/20">{tech}</span>
        ))}
      </div>
      <div class="flex flex-wrap gap-2 mt-4">
        {["Docker", "Kubernetes", "Git", "AWS", "GCP"].map((tech) => (
          <span class="px-3 py-1 rounded-full text-xs font-medium bg-secondary/10 text-secondary border border-secondary/20">{tech}</span>
        ))}
      </div>
    </div>
    
    <!-- Education -->
    <div class="card-modern">
      <h2 class="section-headline">Education</h2>
      <div class="space-y-1">
        <h3 class="text-sm font-bold text-primary">Bachelor Degree (S.Kom)</h3>
        <p class="text-xs text-muted">2006 - 2009 · Stikom Bali</p>
      </div>
    </div>
  </div>
</aside>
